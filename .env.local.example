# =============================================
# TKD-PLATFORM (도장관) Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# App
NEXT_PUBLIC_APP_URL=             # Service URL (local: http://localhost:3000)
NEXT_PUBLIC_SENTRY_DSN=          # Sentry project DSN

# Auth
JWT_SECRET=                      # JWT signing secret (32+ random characters)

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=           # Cloudflare account ID
D1_DATABASE_ID=                  # Cloudflare D1 database ID (tkd-platform)
R2_BUCKET_NAME=tkd-photos        # Cloudflare R2 bucket name
NEXT_PUBLIC_PHOTOS_URL=          # R2 public URL (e.g. https://photos.tkd.genomic.cc)
CLOUDFLARE_SFU_APP_ID=           # Cloudflare Realtime SFU App ID
CLOUDFLARE_SFU_API_TOKEN=        # Cloudflare Realtime SFU API Token

# NHN Cloud (Kakao Alimtalk / LINE)
NHN_CLOUD_APP_KEY=               # NHN Cloud alimtalk app key
NHN_CLOUD_SECRET_KEY=            # NHN Cloud secret key
